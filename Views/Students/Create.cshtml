@model DormitoryManagementSystem.Models.Student
@{
    ViewData["Title"] = "Register Student";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-9">
        <div class="text-center mb-4">
            <h2 class="fw-bolder" style="color: #2c3e50;">Register New Student</h2>
            <p class="text-muted">Enroll a student, assign them to a room. A login account will be auto-created.</p>
        </div>

        <div class="card border-0 shadow-lg" style="border-radius: 20px;">
            <div class="card-body p-5">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-4">
                            <label asp-for="Name" class="form-label fw-bold text-secondary"></label>
                            <input asp-for="Name" class="form-control form-control-lg bg-light border-0" placeholder="First name" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Surname" class="form-label fw-bold text-secondary"></label>
                            <input asp-for="Surname" class="form-control form-control-lg bg-light border-0" placeholder="Last name" />
                            <span asp-validation-for="Surname" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="NationalId" class="form-label fw-bold text-secondary"></label>
                            <input asp-for="NationalId" class="form-control form-control-lg bg-light border-0" placeholder="11-digit TC number" maxlength="11" />
                            <span asp-validation-for="NationalId" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label fw-bold text-secondary"></label>
                            <input asp-for="Email" class="form-control form-control-lg bg-light border-0" placeholder="student@example.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label fw-bold text-secondary"></label>
                            <input asp-for="PhoneNumber" class="form-control form-control-lg bg-light border-0" placeholder="+90 5XX XXX XX XX" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-12">
                            <label asp-for="RoomId" class="form-label fw-bold text-secondary">Assign to Room</label>
                            <select asp-for="RoomId" class="form-select form-select-lg bg-light border-0" asp-items="@(new SelectList(ViewBag.Rooms, "Id", "RoomNumber"))" required>
                                <option value="" disabled selected>-- Please select a room --</option>
                            </select>
                            <span asp-validation-for="RoomId" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label asp-for="MembStartDate" class="form-label fw-bold text-secondary"></label>
                            <input asp-for="MembStartDate" type="date" class="form-control form-control-lg bg-light border-0" />
                            <span asp-validation-for="MembStartDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="MembEndDate" class="form-label fw-bold text-secondary"></label>
                            <input asp-for="MembEndDate" type="date" class="form-control form-control-lg bg-light border-0" />
                            <span asp-validation-for="MembEndDate" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="alert alert-info border-0 rounded-3 py-2 small mt-2">
                        <i class="bi bi-info-circle-fill me-2"></i>
                        <strong>Auto Login Info:</strong> A system account will be created automatically.
                        Username: <code>name.surname</code> | Password: <strong>last 4 TC digits + <code>@@Dorm</code></strong>
                    </div>

                    <div class="d-flex justify-content-between mt-4 border-top pt-4">
                        <a asp-action="Index" class="btn btn-light rounded-pill px-4">🔙 Back to List</a>
                        <button type="submit" class="btn btn-success btn-lg rounded-pill px-5 shadow-sm">Confirm Registration</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
