@model IEnumerable<DormitoryManagementSystem.Models.Student>
@{
    ViewData["Title"] = "Students Roster";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bolder" style="color: #2c3e50;">Students Roster</h2>
    @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
    {
        <a asp-action="Create" class="btn btn-success rounded-pill px-4 shadow-sm">+ Register Student</a>
    }
</div>

<div class="card border-0 shadow-sm" style="border-radius: 16px; overflow: hidden;">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead style="background: #eef2f5;">
                <tr>
                    <th class="ps-4 py-3">Student</th>
                    <th class="py-3">TC Identity</th>
                    <th class="py-3">E-Mail</th>
                    <th class="py-3">Assigned Room</th>
                    <th class="py-3">Membership Period</th>
                    <th class="py-3">Status</th>
                    @if (User.IsInRole("Admin"))
                    {
                        <th class="text-end pe-4 py-3">Actions</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                <tr>
                    <td class="ps-4 fw-bold">
                        <div class="d-flex align-items-center">
                            <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm" style="width: 40px; height: 40px; font-weight: bold; font-size: 1rem; flex-shrink: 0;">
                                @(string.IsNullOrEmpty(item.Name) ? "?" : item.Name.Substring(0, 1).ToUpper())
                            </div>
                            <div>
                                <div>@item.Name @item.Surname</div>
                                <small class="text-muted fw-normal">@item.User?.Username</small>
                            </div>
                        </div>
                    </td>
                    <td class="font-monospace text-secondary">@item.NationalId</td>
                    <td class="text-secondary"><small>@item.Email</small></td>
                    <td>
                        <span class="badge bg-light text-dark border px-3 py-2 rounded-pill">
                            @(item.Room?.RoomNumber ?? "Unassigned")
                        </span>
                    </td>
                    <td>
                        <small class="text-muted"><i class="bi bi-calendar"></i> @item.MembStartDate.ToString("dd MMM yyyy") → @item.MembEndDate.ToString("dd MMM yyyy")</small>
                    </td>
                    <td>
                        @if(DateTime.Now <= item.MembEndDate) {
                            <span class="badge bg-success rounded-pill px-3 py-2">Active</span>
                        } else {
                            <span class="badge bg-secondary rounded-pill px-3 py-2">Expired</span>
                        }
                    </td>
                    @if (User.IsInRole("Admin"))
                    {
                        <td class="text-end pe-4">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info rounded-pill px-3 mb-1">View Profile</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3 mb-1">Edit</a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;">
                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3 mb-1" onclick="return confirm('Are you sure you want to delete this student?');">Delete</button>
                            </form>
                        </td>
                    }
                </tr>
                }
            </tbody>
        </table>
    </div>
</div>
