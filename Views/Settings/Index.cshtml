@model DormitoryManagementSystem.Models.SettingsViewModel
@{
    ViewData["Title"] = "System Settings";
    bool isAdmin = User.IsInRole("Admin");
}

<div class="row mt-4">
    <div class="col-12">
        <h2 class="fw-bolder" style="color: #2c3e50;">
            <i class="bi bi-gear-fill me-2"></i> Settings
        </h2>
        <p class="text-muted">Manage your profile @if(isAdmin){<text>and system configurations</text>}</p>
    </div>
</div>


<div class="card border-0 shadow-sm rounded-4 mt-3">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
        <ul class="nav nav-tabs card-header-tabs" id="settingsTabs" role="tablist">
            @if (isAdmin)
            {
                <li class="nav-item border-0">
                    <a class="nav-link active fw-bold px-4" id="general-tab" data-bs-toggle="tab" href="#general" role="tab" aria-controls="general" aria-selected="true">
                        <i class="bi bi-building me-1"></i> General/Financial
                    </a>
                </li>
                <li class="nav-item border-0">
                    <a class="nav-link fw-bold px-4" id="users-tab" data-bs-toggle="tab" href="#users" role="tab" aria-controls="users" aria-selected="false">
                        <i class="bi bi-people-fill me-1"></i> User Management
                    </a>
                </li>
                <li class="nav-item border-0">
                    <a class="nav-link fw-bold px-4 text-danger" id="security-tab" data-bs-toggle="tab" href="#security" role="tab" aria-controls="security" aria-selected="false">
                        <i class="bi bi-shield-lock-fill me-1"></i> Security & Backup
                    </a>
                </li>
            }
            <li class="nav-item border-0">
                <a class="nav-link @(!isAdmin ? "active" : "") fw-bold px-4" id="profile-tab" data-bs-toggle="tab" href="#profile" role="tab" aria-controls="profile" aria-selected="@((!isAdmin).ToString().ToLower())">
                    <i class="bi bi-person-badge-fill me-1"></i> Personal Profile
                </a>
            </li>
        </ul>
    </div>
    <div class="card-body p-4 p-md-5">
        <div class="tab-content" id="settingsTabsContent">
            
            @if (isAdmin)
            {
                <!-- Tab 1: General/Financial -->
                <div class="tab-pane fade show active" id="general" role="tabpanel" aria-labelledby="general-tab">
                    <h5 class="fw-bold mb-4">Global System Configurations</h5>
                    <form asp-action="UpdateGlobalSettings" method="post">
                        <div class="row g-4">
                            <div class="col-md-6">
                                <label asp-for="GlobalSettings.DormitoryName" class="form-label text-secondary fw-semibold"></label>
                                <input asp-for="GlobalSettings.DormitoryName" class="form-control bg-light border-1" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="GlobalSettings.ContactPhone" class="form-label text-secondary fw-semibold"></label>
                                <input asp-for="GlobalSettings.ContactPhone" class="form-control bg-light border-1" placeholder="+90 5XX XXX XX XX" />
                            </div>
                            <div class="col-12">
                                <label asp-for="GlobalSettings.DormitoryAddress" class="form-label text-secondary fw-semibold"></label>
                                <textarea asp-for="GlobalSettings.DormitoryAddress" class="form-control bg-light border-1" rows="2"></textarea>
                            </div>
                            <div class="col-12">
                                <label asp-for="GlobalSettings.ContactEmail" class="form-label text-secondary fw-semibold"></label>
                                <input asp-for="GlobalSettings.ContactEmail" class="form-control bg-light border-1" placeholder="dormitory@example.com" />
                            </div>
                            
                            <div class="col-12 mt-4"><hr class="text-muted"/></div>
                            
                            <h6 class="fw-bold mb-0">Financial Settings</h6>
                            <div class="col-md-6 mt-3">
                                <label asp-for="GlobalSettings.DefaultMonthlyDue" class="form-label text-secondary fw-semibold"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light">₺</span>
                                    <input asp-for="GlobalSettings.DefaultMonthlyDue" class="form-control border-1 bg-light" />
                                </div>
                            </div>
                            <div class="col-md-6 mt-3">
                                <label asp-for="GlobalSettings.LatePenaltyFee" class="form-label text-secondary fw-semibold"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light">₺</span>
                                    <input asp-for="GlobalSettings.LatePenaltyFee" class="form-control border-1 bg-light" />
                                </div>
                            </div>
                            <div class="col-12 text-end mt-4">
                                <button type="submit" class="btn btn-primary rounded-pill px-4">Save Global Settings</button>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Tab 2: User Management -->
                <div class="tab-pane fade" id="users" role="tabpanel" aria-labelledby="users-tab">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-bold mb-0">Staff & Admin Management</h5>
                        <button type="button" class="btn btn-success rounded-pill px-4 btn-sm" data-bs-toggle="modal" data-bs-target="#createStaffModal">
                            <i class="bi bi-plus-lg"></i> Add New Staff
                        </button>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light text-secondary">
                                <tr>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Username</th>
                                    <th>Role</th>
                                    <th>Status</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.StaffList)
                                {
                                    <tr>
                                        <td><span class="fw-bold">@item.FullName</span></td>
                                        <td>@item.Email</td>
                                        <td><code>@item.User?.Username</code></td>
                                        <td>
                                            @if (item.User?.RoleId == 1) { <span class="badge bg-danger">Admin</span> }
                                            else { <span class="badge bg-secondary">Staff</span> }
                                        </td>
                                        <td>
                                            @if (item.User?.IsActive == true) { <span class="badge bg-success bg-opacity-25 text-success">Active</span> }
                                            else { <span class="badge bg-secondary bg-opacity-25 text-secondary">Inactive</span> }
                                        </td>
                                        <td class="text-end">
                                            @if (item.User?.Id != int.Parse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0"))
                                            {
                                                <form asp-action="ToggleUserStatus" method="post" class="d-inline">
                                                    <input type="hidden" name="userId" value="@item.User?.Id" />
                                                    <button type="submit" class="btn btn-sm @(item.User?.IsActive == true ? "btn-outline-danger" : "btn-outline-success") rounded-circle" title="Toggle Status">
                                                        <i class="bi @(item.User?.IsActive == true ? "bi-person-x-fill" : "bi-person-check-fill")"></i>
                                                    </button>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Tab 3: Security & Backup -->
                <div class="tab-pane fade" id="security" role="tabpanel" aria-labelledby="security-tab">
                    <h5 class="fw-bold mb-3 text-danger"><i class="bi bi-exclamation-triangle-fill"></i> Danger Zone</h5>
                    <div class="border border-danger border-2 rounded-3 p-4 mb-5 bg-danger bg-opacity-10">
                        <div class="row align-items-center">
                            <div class="col-md-8">
                                <h6 class="fw-bold text-danger mb-1">Database Backup</h6>
                                <p class="text-muted mb-0 small">Download the entire SQLite database file containing all application data. Ensure this file is kept secure as it contains sensitive information.</p>
                            </div>
                            <div class="col-md-4 text-end">
                                <a asp-action="DownloadBackup" class="btn btn-danger fw-bold rounded-pill px-4">
                                    <i class="bi bi-download me-2"></i> Download .db Backup
                                </a>
                            </div>
                        </div>
                    </div>

                    <h5 class="fw-bold mb-3 mt-4">System Audit Logs (Last 100)</h5>
                    <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                        <table class="table table-sm table-hover align-middle" style="font-size: 0.9rem;">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th>Time</th>
                                    <th>User</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in Model.RecentLogs)
                                {
                                    <tr>
                                        <td class="text-muted">@log.Timestamp.ToString("g")</td>
                                        <td class="fw-bold">@(log.User?.Username ?? "Unknown")</td>
                                        <td>@log.ActionDesc</td>
                                    </tr>
                                }
                                @if(!Model.RecentLogs.Any())
                                {
                                    <tr><td colspan="3" class="text-center text-muted">No logs recorded yet.</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            <!-- Tab 4: Profile Settings -->
            <div class="tab-pane fade @(!isAdmin ? "show active" : "")" id="profile" role="tabpanel" aria-labelledby="profile-tab">
                <h5 class="fw-bold mb-4">Change Password</h5>
                <form asp-action="UpdateProfile" method="post">
                    <div class="row g-4 justify-content-center">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="ProfileSettings.CurrentPassword" class="form-label fw-semibold text-secondary"></label>
                                <input asp-for="ProfileSettings.CurrentPassword" type="password" class="form-control bg-light border-1" required />
                                <span asp-validation-for="ProfileSettings.CurrentPassword" class="text-danger small"></span>
                            </div>
                            <div class="mb-3">
                                <label asp-for="ProfileSettings.NewPassword" class="form-label fw-semibold text-secondary"></label>
                                <input asp-for="ProfileSettings.NewPassword" type="password" class="form-control bg-light border-1" required />
                                <span asp-validation-for="ProfileSettings.NewPassword" class="text-danger small"></span>
                            </div>
                            <div class="mb-4">
                                <label asp-for="ProfileSettings.ConfirmPassword" class="form-label fw-semibold text-secondary"></label>
                                <input asp-for="ProfileSettings.ConfirmPassword" type="password" class="form-control bg-light border-1" required />
                                <span asp-validation-for="ProfileSettings.ConfirmPassword" class="text-danger small"></span>
                            </div>
                            <div class="text-center">
                                <button type="submit" class="btn btn-primary rounded-pill px-5 w-100">Update Password</button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>

@if (isAdmin)
{
    <!-- Create Staff Modal -->
    <div class="modal fade" id="createStaffModal" tabindex="-1" aria-labelledby="createStaffModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold" id="createStaffModalLabel">Add New Staff</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <form asp-action="CreateStaff" method="post">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">First Name</label>
                                <input type="text" name="Name" class="form-control bg-light border-1" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Last Name</label>
                                <input type="text" name="Surname" class="form-control bg-light border-1" required />
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-semibold">Email Account</label>
                                <input type="email" name="Email" class="form-control bg-light border-1" required />
                            </div>
                            <div class="col-12 mt-4"><hr class="text-muted"/></div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Username</label>
                                <input type="text" name="Username" class="form-control bg-light border-1" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Temporary Password</label>
                                <input type="text" name="Password" class="form-control bg-light border-1" value="tempPassword123" required />
                            </div>
                        </div>
                        <div class="mt-4 pt-3 border-top text-end">
                            <button type="button" class="btn btn-light rounded-pill px-4 me-2" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-success rounded-pill px-4">Create Account</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
}
