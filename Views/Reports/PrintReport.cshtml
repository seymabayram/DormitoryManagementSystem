@{
    Layout = null;
    var dataAsOf = (string)(ViewBag.DataAsOf ?? "");
    var type = (string)(ViewBag.ReportType ?? "consolidated");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@(type == "overdue" ? "Overdue Details Report" : "Consolidated Management Summary") - @dataAsOf</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'Segoe UI', Arial, sans-serif; font-size: 12px; color: #1a202c; padding: 40px; line-height: 1.5; }
        .header { display: flex; justify-content: space-between; align-items: flex-end; border-bottom: 2px solid #2d3748; padding-bottom: 10px; margin-bottom: 30px; }
        .header h1 { font-size: 24px; color: #1a1f5e; margin: 0; }
        .header .meta { text-align: right; font-size: 11px; color: #718096; }
        
        h2 { font-size: 14px; text-transform: uppercase; letter-spacing: 1px; color: #4a5568; margin: 30px 0 12px; display: flex; align-items: center; gap: 8px; }
        h2::after { content: ''; flex: 1; height: 1px; background: #e2e8f0; }

        .metrics-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-bottom: 10px; }
        .metric-card { border: 1px solid #e2e8f0; border-radius: 12px; padding: 20px; background: #fff; }
        .metric-card.finance { border-left: 5px solid #3182ce; }
        .metric-card.occupancy { border-left: 5px solid #38a169; }
        
        .metric-row { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid #f7fafc; }
        .metric-row:last-child { border-bottom: none; }
        .metric-label { color: #718096; font-weight: 600; font-size: 11px; }
        .metric-value { font-weight: 700; color: #2d3748; font-size: 13px; }
        .metric-value.highlight { color: #2b6cb0; font-size: 18px; }

        table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        th { background: #f7fafc; border-bottom: 2px solid #cbd5e0; padding: 12px 10px; text-align: left; font-size: 10px; color: #4a5568; text-transform: uppercase; }
        td { border-bottom: 1px solid #edf2f7; padding: 10px; font-size: 11px; }
        tr:nth-child(even) { background-color: #fcfcfc; }
        
        .badge { display: inline-block; padding: 4px 10px; border-radius: 20px; font-size: 10px; font-weight: 700; text-transform: uppercase; }
        .badge-danger { background: #fed7d7; color: #c53030; }

        .footer { margin-top: 50px; padding-top: 20px; border-top: 1px solid #e2e8f0; text-align: center; color: #a0aec0; font-size: 10px; }

        .no-print { position: fixed; top: 20px; right: 20px; display: flex; gap: 10px; z-index: 1000; }
        .btn { padding: 10px 20px; border-radius: 8px; text-decoration: none; font-weight: 700; font-size: 13px; cursor: pointer; border: none; transition: 0.2s; }
        .btn-primary { background: #3182ce; color: #fff; box-shadow: 0 4px 6px rgba(49, 130, 206, 0.2); }
        .btn-light { background: #edf2f7; color: #4a5568; }

        @@media print {
            .no-print { display: none !important; }
            body { padding: 0; }
            .metric-card { break-inside: avoid; }
        }
    </style>
</head>
<body>
    <div class="no-print">
        <button onclick="window.print()" class="btn btn-primary">🖨️ Print Report / Save PDF</button>
        <button onclick="window.close()" class="btn btn-light">Close</button>
    </div>

    <div class="header">
        <div>
            <h1>Dormitory Management System</h1>
            <p style="color: #4a5568; font-weight: 600; margin-top: 5px;">@(type == "overdue" ? "Detailed Overdue Resident Report" : "Consolidated Financial & Occupancy Summary")</p>
        </div>
        <div class="meta">
            Generated by Admin<br>
            @dataAsOf
        </div>
    </div>

    @if (type == "consolidated")
    {
        <h2>Financial Performance Highlights</h2>
        <div class="metrics-grid">
            <div class="metric-card finance">
                <div class="metric-row">
                    <span class="metric-label">Total Collected Revenue</span>
                    <span class="metric-value highlight">₺@(((decimal)(ViewBag.CollectedRevenue ?? 0m)).ToString("N0"))</span>
                </div>
                <div class="metric-row">
                    <span class="metric-label">Outstanding Debt</span>
                    <span class="metric-value" style="color:#c53030;">₺@(((decimal)(ViewBag.TotalOverdue ?? 0m)).ToString("N0"))</span>
                </div>
                <div class="metric-row">
                    <span class="metric-label">Current Collection Rate</span>
                    <span class="metric-value">@ViewBag.CollectionRate %</span>
                </div>
            </div>

            <div class="metric-card occupancy">
                <div class="metric-row">
                    <span class="metric-label">Physical Unit Capacity</span>
                    <span class="metric-value highlight">@ViewBag.TotalCapacity Beds</span>
                </div>
                <div class="metric-row">
                    <span class="metric-label">Total Active Residents</span>
                    <span class="metric-value">@ViewBag.OccupiedBeds Students</span>
                </div>
                <div class="metric-row">
                    <span class="metric-label">Overall Occupancy Rate</span>
                    <span class="metric-value">@ViewBag.OccupancyRate %</span>
                </div>
            </div>
        </div>

        <p style="color: #718096; font-size: 11px; font-style: italic; margin-top: 20px;">
            * This report provides a high-level overview of the facility's cash flow and unit utilization for management review purposes.
        </p>
    }
    else if (type == "overdue")
    {
        <h2>Detailed Overdue Payments List</h2>
        <table>
            <thead>
                <tr>
                    <th style="width: 25%;">Student Name</th>
                    <th style="width: 10%;">Room</th>
                    <th style="width: 30%;">Debt Type</th>
                    <th style="width: 15%;">Amount (₺)</th>
                    <th style="width: 15%;">Days Overdue</th>
                    <th style="width: 5%;">Status</th>
                </tr>
            </thead>
            <tbody>
                @if (ViewBag.OverdueList != null)
                {
                    foreach (var item in ViewBag.OverdueList)
                    {
                        <tr>
                            <td style="font-weight: 700;">@item.StudentName</td>
                            <td>@item.Room</td>
                            <td>@item.Type</td>
                            <td style="font-weight: 700; color: #c53030;">₺@(((decimal)item.Amount).ToString("N0"))</td>
                            <td>@item.DaysOverdue Days Late</td>
                            <td><span class="badge badge-danger">Unpaid</span></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    }

    <div class="footer">
        Dormitory Management System &copy; @DateTime.Now.Year &bull; Confidential Management Report
    </div>
</body>
</html>
