@{
    Layout = null; // Sidebar olmadan tam sayfa
    var collected = (decimal)(ViewBag.CollectedRevenue ?? 0m);
    var overdue   = (decimal)(ViewBag.TotalOverdue ?? 0m);
    var total     = (decimal)(ViewBag.TotalTarget ?? 0m);
    var rate      = (double)(ViewBag.CollectionRate ?? 0.0);
    var dataAsOf  = (string)(ViewBag.DataAsOf ?? "");
    var overdueList   = ViewBag.OverdueList as IEnumerable<dynamic>;
    var allPayments   = ViewBag.AllPayments as IEnumerable<dynamic>;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Dormitory Report - @dataAsOf</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: Arial, sans-serif; font-size: 12px; color: #222; padding: 30px; }
        h1 { font-size: 20px; margin-bottom: 4px; }
        h2 { font-size: 14px; margin: 20px 0 8px; border-bottom: 2px solid #333; padding-bottom: 4px; }
        .meta { color: #666; font-size: 11px; margin-bottom: 20px; }
        .metrics { display: flex; gap: 16px; margin-bottom: 24px; }
        .metric-box { flex: 1; border: 1px solid #ccc; border-radius: 8px; padding: 12px; text-align: center; }
        .metric-box .label { font-size: 10px; color: #666; text-transform: uppercase; }
        .metric-box .value { font-size: 20px; font-weight: bold; margin-top: 4px; }
        .green  { border-color: #27ae60; color: #27ae60; }
        .orange { border-color: #e67e22; color: #e67e22; }
        .red    { border-color: #e74c3c; color: #e74c3c; }
        .blue   { border-color: #2980b9; color: #2980b9; }
        table { width: 100%; border-collapse: collapse; margin-bottom: 20px; font-size: 11px; }
        th { background: #f0f0f0; border: 1px solid #ccc; padding: 6px 8px; text-align: left; font-size: 10px; text-transform: uppercase; }
        td { border: 1px solid #ddd; padding: 6px 8px; }
        tr:nth-child(even) td { background: #fafafa; }
        .paid   { color: #27ae60; font-weight: bold; }
        .unpaid { color: #e74c3c; font-weight: bold; }
        .footer { margin-top: 30px; text-align: center; font-size: 10px; color: #999; border-top: 1px solid #eee; padding-top: 12px; }
        @@media print {
            body { padding: 15px; }
            .no-print { display: none !important; }
        }
    </style>
</head>
<body>
    <div class="no-print" style="text-align:right;margin-bottom:20px;">
        <button onclick="window.print()" style="padding:10px 24px;background:#2980b9;color:#fff;border:none;border-radius:6px;font-size:13px;cursor:pointer;">
            🖨️ Print / Save as PDF
        </button>
        <button onclick="window.close()" style="padding:10px 18px;background:#aaa;color:#fff;border:none;border-radius:6px;font-size:13px;cursor:pointer;margin-left:8px;">
            Close
        </button>
        <p style="font-size:11px;color:#666;margin-top:6px;">To save as PDF, select <strong>"Destination: Save as PDF"</strong> in the print dialog.</p>
    </div>

    <h1>🏢 Dormitory Management System</h1>
    <div class="meta">Financial Report &bull; Generated: @dataAsOf</div>

    <h2>Key Financial Metrics</h2>
    <div class="metrics">
        <div class="metric-box green">
            <div class="label">Collected Revenue</div>
            <div class="value green">₺@collected.ToString("N0")</div>
        </div>
        <div class="metric-box orange">
            <div class="label">Total Overdue</div>
            <div class="value orange">₺@overdue.ToString("N0")</div>
        </div>
        <div class="metric-box red">
            <div class="label">Total Target</div>
            <div class="value red">₺@total.ToString("N0")</div>
        </div>
        <div class="metric-box blue">
            <div class="label">Collection Rate</div>
            <div class="value blue">@rate%</div>
        </div>
    </div>

    <h2>Overdue Payments</h2>
    @if (overdueList != null && overdueList.Any())
    {
        <table>
            <thead>
                <tr>
                    <th>Student Name</th>
                    <th>Room</th>
                    <th>Description</th>
                    <th>Amount (₺)</th>
                    <th>Due Date</th>
                    <th>Days Overdue</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in overdueList)
                {
                    <tr>
                        <td>@item.StudentName</td>
                        <td>@item.Room</td>
                        <td>@item.Type</td>
                        <td>₺@(((decimal)item.Amount).ToString("N0"))</td>
                        <td>@(((DateTime)item.DueDate).ToString("dd/MM/yyyy"))</td>
                        <td class="unpaid">@item.DaysOverdue days</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p style="color:#27ae60;padding:12px;">✅ No overdue payments.</p>
    }

    @if (allPayments != null)
    {
        <h2>All Payments</h2>
        <table>
            <thead>
                <tr>
                    <th>Student</th>
                    <th>Room</th>
                    <th>Description</th>
                    <th>Amount (₺)</th>
                    <th>Due Date</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in allPayments)
                {
                    <tr>
                        <td>@(d.Student?.FullName ?? "Unknown")</td>
                        <td>@(d.Student?.Room?.RoomNumber ?? "N/A")</td>
                        <td>@d.Description</td>
                        <td>₺@(((decimal)d.Amount).ToString("N0"))</td>
                        <td>@(((DateTime)d.DueDate).ToString("dd/MM/yyyy"))</td>
                        <td class="@(d.IsPaid ? "paid" : "unpaid")">@(d.IsPaid ? "✅ Paid" : "❌ Unpaid")</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <div class="footer">
        Dormitory Management System &copy; @DateTime.Now.Year &bull; Report generated on @dataAsOf
    </div>
</body>
</html>
