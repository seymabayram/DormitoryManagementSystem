<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Dormitory Management</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
        body {
            font-family: 'Outfit', sans-serif;
            background: linear-gradient(135deg, #f6f8fd 0%, #f1f5f9 100%);
            background-attachment: fixed;
            color: #2c3e50;
            overflow-x: hidden;
        }
        
        /* Premium Fixed Sidebar */
        .sidebar {
            min-width: 260px;
            max-width: 260px;
            min-height: 100vh;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(20px);
            border-right: 1px solid rgba(0,0,0,0.05);
            box-shadow: 4px 0 25px rgba(0,0,0,0.03);
            position: fixed;
            top: 0; left: 0;
            padding-top: 30px;
            z-index: 1000;
            display: flex;
            flex-direction: column;
        }

        .sidebar-brand {
            font-weight: 800;
            background: linear-gradient(45deg, #1cb5e0, #000046);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-size: 1.6rem;
            text-align: center;
            margin-bottom: 2rem;
            text-decoration: none;
        }

        .nav-item { margin: 5px 15px; list-style: none; }
        .nav-link {
            font-weight: 600;
            color: #6c7a89 !important;
            padding: 12px 20px;
            border-radius: 12px;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
        }
        .nav-link i { font-size: 1.2rem; margin-right: 12px; }
        .nav-link:hover, .nav-link.active {
            background: #f0f4f8;
            color: #1cb5e0 !important;
            transform: translateX(5px);
        }

        /* Content Area Setup */
        .content-area {
            width: calc(100% - 260px);
            margin-left: 260px;
            min-height: 100vh;
            padding: 40px;
        }

        .page-transition { animation: fadeInDown 0.6s cubic-bezier(0.25, 0.8, 0.25, 1); }

        @@keyframes fadeInDown {
            from { opacity: 0; transform: translateY(15px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .btn { border-radius: 12px; font-weight: 600; transition: all 0.3s ease; }
        .btn:hover { transform: translateY(-3px) scale(1.02); box-shadow: 0 10px 20px rgba(0,0,0,0.15); }
        .table { background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(10px); border-radius: 15px; overflow: hidden; margin-bottom: 0;}
        .table tbody tr { transition: all 0.3s ease; }
        .table tbody tr:hover { background-color: rgba(255,255,255,1); transform: scale(1.01); box-shadow: 0 5px 15px rgba(0,0,0,0.05); z-index: 10; position: relative; }
        
        .form-control, .form-select { border-radius: 12px; border: 1px solid rgba(0,0,0,0.1); background: rgba(255,255,255,0.7); transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        .form-control:focus, .form-select:focus { border-color: #1cb5e0; background: #fff; box-shadow: 0 0 0 4px rgba(28, 181, 224, 0.15); transform: translateY(-2px); }
        
        .card { transition: all 0.4s ease; border: none; background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(15px); }
        .card:hover { transform: translateY(-10px); box-shadow: 0 20px 40px rgba(0,0,0,0.08); }

        footer { margin-top: 50px; background: rgba(255,255,255,0.5); backdrop-filter: blur(10px); color: #6c7a89; padding: 25px 0; border-top: 1px solid rgba(0,0,0,0.05); border-radius: 20px; font-weight: 500;}
    </style>
</head>
<body>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="sidebar">
            <a class="sidebar-brand" asp-controller="Home" asp-action="Index">
                <i class="bi bi-building"></i> Dormitory
            </a>
            
            <ul class="p-0 flex-grow-1">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Index"><i class="bi bi-grid-1x2-fill"></i> Dashboard</a>
                </li>
                @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Rooms" asp-action="Index"><i class="bi bi-door-open-fill"></i> Rooms</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Students" asp-action="Index"><i class="bi bi-person-badge-fill"></i> Students</a>
                    </li>
                }
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Dues" asp-action="Index"><i class="bi bi-wallet-fill"></i> Finances</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Maintenance" asp-action="Index"><i class="bi bi-tools"></i> Maintenance</a>
                </li>
            </ul>

            <div class="mt-auto p-4 border-top opacity-75 text-center">
                <strong class="d-block mb-2 text-success">@User.Identity?.Name</strong>
                <a class="btn btn-outline-danger btn-sm rounded-pill w-100" asp-controller="Account" asp-action="Logout">Logout</a>
            </div>
        </div>
    }

    <div class="@(User.Identity?.IsAuthenticated == true ? "content-area" : "container-fluid") page-transition" style="@(User.Identity?.IsAuthenticated != true ? "padding-top: 80px;" : "")">
        <main role="main" class="pb-5" data-aos="fade-in" data-aos-duration="800">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show rounded-pill shadow-sm border-0 mb-4 px-4" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show rounded-pill shadow-sm border-0 mb-4 px-4" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @RenderBody()
        </main>
        
        <footer class="text-center shadow-sm" data-aos="fade-up" data-aos-anchor-placement="bottom-bottom">
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-md-6 text-md-start mb-3 mb-md-0">
                        <span class="fs-5 fw-bold" style="background: linear-gradient(45deg, #1cb5e0, #000046); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Dormitory Premium</span> &copy; @DateTime.Now.Year
                    </div>
                    <div class="col-md-6 text-md-end">
                        <a href="#" class="text-decoration-none text-secondary mx-2 hover-text-primary"><i class="bi bi-shield-check"></i> Privacy Policy</a>
                        <a href="#" class="text-decoration-none text-secondary mx-2 hover-text-primary"><i class="bi bi-envelope"></i> Contact Support</a>
                    </div>
                </div>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        AOS.init({
            once: false, /* allow animations to occur every scroll */
            mirror: true,
            offset: 50,
            duration: 600,
            easing: 'ease-out-cubic'
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
