@model IEnumerable<DormitoryManagementSystem.Models.Room>
@{
    ViewData["Title"] = "Rooms Management";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bolder" style="color: #2c3e50;">Room List</h2>
    <a asp-controller="Rooms" asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">+ Add New Room</a>
</div>

<div class="card border-0 shadow-sm" style="border-radius: 16px; overflow: hidden;">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead style="background: #f8f9fa;">
                <tr>
                    <th class="ps-4 py-3">Room Number</th>
                    <th class="py-3">Bed Capacity</th>
                    <th class="text-end pe-4 py-3">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var room in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold text-primary">@room.RoomNumber</td>
                        <td><span class="badge bg-info text-dark rounded-pill px-3 py-2">@room.Capacity Beds</span></td>
                        <td class="text-end pe-4">
                            <a asp-action="Edit" asp-route-id="@room.Id" class="btn btn-sm btn-outline-secondary rounded-pill px-3">Edit</a>
                            <form asp-action="Delete" asp-route-id="@room.Id" method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3" onclick="return confirm('Bu odayı silmek istediğinize emin misiniz? (Are you sure?)');">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>