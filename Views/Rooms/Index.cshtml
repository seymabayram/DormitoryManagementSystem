@model IEnumerable<DormitoryManagementSystem.Models.Room>
@{
    ViewData["Title"] = "Rooms Management";
}

<div class="page-header" data-aos="fade-down">
    <div>
        <div class="page-title">Rooms Management
            <span>Configure dormitory room inventory</span>
        </div>
    </div>
    <a asp-controller="Rooms" asp-action="Create" class="btn-primary-action">
        <i class="bi bi-plus-lg"></i> Add New Room
    </a>
</div>

<!-- Summary Chips -->
<div class="d-flex gap-3 mb-4 flex-wrap" data-aos="fade-up" data-aos-delay="50">
    <div style="background:white;border-radius:12px;padding:10px 18px;box-shadow:0 2px 12px rgba(26,31,94,0.07);display:flex;align-items:center;gap:10px;">
        <div style="width:36px;height:36px;border-radius:10px;background:#eff6ff;color:#1A3A8A;display:flex;align-items:center;justify-content:center;font-size:1rem;"><i class="bi bi-door-open-fill"></i></div>
        <div>
            <div style="font-size:1.1rem;font-weight:800;color:#1A1F5E;">@Model.Count()</div>
            <div style="font-size:0.72rem;color:#94a3b8;font-weight:600;">ROOMS</div>
        </div>
    </div>
    <div style="background:white;border-radius:12px;padding:10px 18px;box-shadow:0 2px 12px rgba(26,31,94,0.07);display:flex;align-items:center;gap:10px;">
        <div style="width:36px;height:36px;border-radius:10px;background:#f0fdf4;color:#2D7D4A;display:flex;align-items:center;justify-content:center;font-size:1rem;"><i class="bi bi-people-fill"></i></div>
        <div>
            <div style="font-size:1.1rem;font-weight:800;color:#166534;">@Model.Sum(r => r.Capacity)</div>
            <div style="font-size:0.72rem;color:#94a3b8;font-weight:600;">TOTAL BEDS</div>
        </div>
    </div>
</div>

<div class="table-card" data-aos="fade-up" data-aos-delay="100">
    <div class="table-card-header">
        <div class="table-card-title">
            <i class="bi bi-door-open-fill"></i> Room Inventory
        </div>
    </div>
    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th style="padding-left:20px;">#</th>
                    <th>Room Number</th>
                    <th>Bed Capacity</th>
                    <th style="text-align:right; padding-right:20px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" style="text-align:center;padding:48px 20px;color:#94a3b8;">
                            <i class="bi bi-door-open" style="font-size:2.5rem;display:block;margin-bottom:10px;opacity:0.4;"></i>
                            No rooms added yet.
                        </td>
                    </tr>
                }
                @{ int rowIndex = 1; }
                @foreach (var room in Model)
                {
                    <tr>
                        <td style="padding-left:20px; color:#94a3b8; font-weight:600; font-size:0.85rem;">@rowIndex</td>
                        <td>
                            <div style="display:flex;align-items:center;gap:12px;">
                                <div style="width:38px;height:38px;border-radius:10px;background:#eff6ff;color:#1A3A8A;display:flex;align-items:center;justify-content:center;font-size:1rem;">
                                    <i class="bi bi-door-open-fill"></i>
                                </div>
                                <span style="font-weight:700;color:#1A1F5E;font-size:1rem;">@room.RoomNumber</span>
                            </div>
                        </td>
                        <td>
                            <div style="display:flex;align-items:center;gap:8px;">
                                @for (int b = 0; b < room.Capacity; b++)
                                {
                                    <i class="bi bi-person-fill" style="color:#3A6BC7;font-size:0.95rem;"></i>
                                }
                                <span class="badge-room" style="margin-left:4px;">@room.Capacity Beds</span>
                            </div>
                        </td>
                        <td style="text-align:right;padding-right:20px;">
                            <div style="display:flex;gap:6px;justify-content:flex-end;">
                                <a asp-action="Edit" asp-route-id="@room.Id" class="btn-action btn-edit"><i class="bi bi-pencil"></i> Edit</a>
                                <form asp-action="Delete" asp-route-id="@room.Id" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-action btn-delete" onclick="return confirm('Delete this room?')">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    rowIndex++;
                }
            </tbody>
        </table>
    </div>
</div>