@model IEnumerable<DormitoryManagementSystem.Models.MaintenanceTicket>
@{
    ViewData["Title"] = "Maintenance Tickets";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bolder" style="color: #2c3e50;">Service & Repair Tickets</h2>
    <a asp-action="Create" class="btn btn-danger rounded-pill px-4 shadow-sm">+ File New Ticket</a>
</div>

<div class="card border-0 shadow-sm" style="border-radius: 16px; overflow: hidden;">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead style="background: #fdf5f5;">
                <tr>
                    <th class="ps-4 py-3">Ticket ID</th>
                    <th class="py-3">Reporter</th>
                    <th class="py-3">Room</th>
                    <th class="py-3">Issue</th>
                    <th class="py-3">Status</th>
                    <th class="text-end pe-4 py-3">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                <tr>
                    <td class="ps-4 font-monospace">#@item.Id.ToString("D5")</td>
                    <td>
                        <div class="fw-bold text-dark">@(item.Student?.FullName ?? "Unknown")</div>
                    </td>
                    <td>
                        <span class="badge bg-light text-dark border">@(item.Room?.RoomNumber ?? "N/A")</span>
                    </td>
                    <td>
                        <div class="text-truncate" style="max-width: 250px;">@item.Issue</div>
                    </td>
                    <td>
                        @if(item.IsResolved) {
                            <span class="badge bg-success bg-opacity-25 text-success border border-success rounded-pill px-3 py-1">Resolved</span>
                        } else {
                            <span class="badge bg-warning bg-opacity-25 text-warning border border-warning rounded-pill px-3 py-1 animate__animated animate__pulse animate__infinite">Pending</span>
                        }
                    </td>
                    <td class="text-end pe-4">
                        @if (!item.IsResolved && (User.IsInRole("Admin") || User.IsInRole("Staff")))
                        {
                            <form asp-action="Resolve" asp-route-id="@item.Id" method="post" style="display:inline;">
                                <button type="submit" class="btn btn-sm btn-outline-success rounded-pill fw-bold px-3">Mark Resolved</button>
                            </form>
                        }
                    </td>
                </tr>
                }
            </tbody>
        </table>
    </div>
</div>
