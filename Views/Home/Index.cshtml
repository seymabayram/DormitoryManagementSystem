@{
    ViewData["Title"] = "Executive Dashboard";
    ViewData["IsHomePage"] = true;
}

<style>
    /* Premium Interactive Design System */
    .glass-card {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 20px;
        box-shadow: 0 10px 40px 0 rgba(0, 0, 0, 0.4);
        transition: all 0.3s ease;
        color: #fff;
    }
    
    .gradient-text {
        background: linear-gradient(135deg, #fff 0%, #4fc3f7 50%, #81c784 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        font-weight: 800;
        letter-spacing: -1.5px;
    }

    /* Top Information Bar - Filling the gap */
    .top-status-bar {
        position: absolute;
        top: 25px;
        left: 50%;
        transform: translateX(-50%);
        width: 100%;
        max-width: 900px;
        display: flex;
        justify-content: center;
        gap: 30px;
        z-index: 100;
    }
    .status-item {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: rgba(255,255,255,0.6);
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .status-dot { width: 6px; height: 6px; background: #00ff7f; border-radius: 50%; box-shadow: 0 0 8px #00ff7f; }

    /* Balanced Vertical Layout */
    .dashboard-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding-top: 2rem; /* Boşluk azaltıldı */
        padding-bottom: 5rem;
        min-height: 85vh;
        position: relative;
    }

    /* Diversified Building Colors */
    .hero-building {
        width: 100%;
        max-width: 500px;
        margin-bottom: 1.5rem;
        opacity: 0.98;
        filter: drop-shadow(0 0 60px rgba(79, 195, 247, 0.25));
    }
    .face-top { fill: #e0f7fa; }  /* Parlak Üst */
    .face-left { fill: #1a232e; } /* Koyu Sol */
    .face-right { fill: #37474f; } /* Orta Sağ */
    .window-glow { fill: #00e5ff; filter: drop-shadow(0 0 10px #00e5ff); }
    .window-warm { fill: #ffd54f; filter: drop-shadow(0 0 10px #ffd54f); }

    /* Atmosphere Effects */
    #starCanvas {
        position: fixed;
        top: 0; left: 0; width: 100%; height: 100%;
        z-index: -2;
        pointer-events: none;
    }

    .nebula {
        position: fixed;
        top: 0; left: 0; width: 100%; height: 100%;
        background: radial-gradient(circle at 20% 30%, rgba(79, 195, 247, 0.05) 0%, transparent 40%),
                    radial-gradient(circle at 80% 70%, rgba(129, 199, 132, 0.05) 0%, transparent 40%),
                    radial-gradient(circle at 50% 10%, rgba(156, 39, 176, 0.03) 0%, transparent 50%);
        z-index: -1;
        pointer-events: none;
    }

    /* KPI Row */
    .kpi-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 24px;
        width: 100%;
        margin-top: 2.5rem;
    }

    .kpi-card {
        padding: 28px;
        border-bottom: 5px solid transparent;
        color: #fff;
    }
    .kpi-card .card-label { font-size: 0.8rem; font-weight: 700; text-transform: uppercase; color: #94a3b8; letter-spacing: 2px; margin-bottom: 12px; }
    .kpi-card .card-value { font-size: 2.5rem; font-weight: 800; line-height: 1; margin-bottom: 10px; }
    
    .border-blue { border-bottom-color: #2196f3; }
    .border-green { border-bottom-color: #4caf50; }
    .border-red { border-bottom-color: #f44336; }
    .border-amber { border-bottom-color: #ffc107; }

    .text-blue { color: #4fc3f7; }
    .text-green { color: #81c784; }
    .text-red { color: #ff8a80; }
    .text-amber { color: #ffd54f; }

    @@keyframes float {
        0%, 100% { transform: translateY(0px) rotate(0.2deg); }
        50% { transform: translateY(-25px) rotate(-0.2deg); }
    }
    .floating-anim { animation: float 7s ease-in-out infinite; }

</style>

<canvas id="starCanvas"></canvas>
<div class="nebula"></div>

<div class="container">
    
    <!-- Top Status Bar - Filling the Gap -->
    <div class="top-status-bar animate__animated animate__fadeInDown">
        <div class="status-item">
            <div class="status-dot"></div>
            System Health: Optimal
        </div>
        <div class="status-item">
            <i class="bi bi-shield-check text-blue"></i>
            Encrypted Node
        </div>
        <div class="status-item">
            <i class="bi bi-people-fill text-green"></i>
            Live Operations
        </div>
    </div>

    <div class="dashboard-container animate__animated animate__fadeIn">
        
        <!-- Highly Detailed Building -->
        <div class="hero-building floating-anim">
            <svg viewBox="0 0 500 500" width="100%">
                <ellipse cx="250" cy="420" rx="190" ry="50" fill="rgba(0,0,0,0.4)" />
                <polygon class="face-left" points="100,200 250,280 250,480 100,400" />
                <polygon class="face-right" points="250,280 400,200 400,400 250,480" />
                <polygon class="face-top" points="100,200 250,120 400,200 250,280" />
                
                <!-- Random Multi-color Windows -->
                <rect class="window-glow" x="135" y="275" width="18" height="12" transform="skewY(28)" />
                <rect class="window-warm" x="135" y="325" width="18" height="12" transform="skewY(28)" />
                <rect class="window-glow" x="175" y="275" width="18" height="12" transform="skewY(28)" />
                <rect class="window-glow" x="315" y="365" width="18" height="12" transform="skewY(-28)" />
                <rect class="window-warm" x="315" y="415" width="18" height="12" transform="skewY(-28)" />
                <rect class="window-glow" x="355" y="365" width="18" height="12" transform="skewY(-28)" />
            </svg>
        </div>

        <div class="mb-4">
            <h1 class="display-2 gradient-text mb-2">Dormitory Management System</h1>
            <p class="text-muted fs-4 mx-auto" style="max-width: 800px; color: #cfd8dc !important; opacity:0.8;">
                Unified operational hub for state-of-the-art facility monitoring and resident management.
            </p>
        </div>

        @if (User.Identity?.IsAuthenticated != true)
        {
            <div class="mt-4 pb-5">
                <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg rounded-pill px-5 py-3 fs-5 shadow-lg border-0" 
                   style="background: linear-gradient(45deg, #1565C0, #1e88e5); box-shadow: 0 10px 40px rgba(21,101,192,0.4) !important;">
                    Log in
                </a>
            </div>
        }
        else
        {
            <div class="mt-4 pb-5">
                <a asp-controller="Home" asp-action="Dashboard" class="btn btn-success btn-lg rounded-pill px-5 py-3 fs-5 shadow-lg border-0" 
                   style="background: linear-gradient(45deg, #2e7d32, #43a047); box-shadow: 0 10px 40px rgba(46,125,50,0.4) !important;">
                    Go to Dashboard
                </a>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Star Field Engine
        const canvas = document.getElementById('starCanvas');
        const ctx = canvas.getContext('2d');
        let stars = [];

        function initStars() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
            stars = [];
            for(let i=0; i<180; i++) {
                stars.push({
                    x: Math.random() * canvas.width,
                    y: Math.random() * canvas.height,
                    size: Math.random() * 2 + 0.2,
                    opacity: Math.random() * 0.6,
                    speed: Math.random() * 0.12 + 0.05
                });
            }
        }

        function animateStars() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            stars.forEach(s => {
                ctx.fillStyle = `rgba(255, 255, 255, ${s.opacity})`;
                ctx.beginPath();
                ctx.arc(s.x, s.y, s.size, 0, Math.PI * 2);
                ctx.fill();
                s.y -= s.speed;
                if(s.y < 0) s.y = canvas.height;
            });
            requestAnimationFrame(animateStars);
        }

        window.addEventListener('resize', initStars);
        initStars();
        animateStars();
    </script>
}
