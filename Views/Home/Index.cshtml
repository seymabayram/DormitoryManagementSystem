@{
    ViewData["Title"] = "Executive Dashboard";
}

<style>
    /* Premium Glassmorphism & UI Tuning */
    .glass-card {
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.4);
        border-radius: 16px;
        box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.07);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .glass-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 40px 0 rgba(31, 38, 135, 0.15);
    }
    .gradient-text {
        background: linear-gradient(45deg, #2b5876, #4e4376);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .stat-number {
        font-size: 2.5rem;
        font-weight: 800;
        margin: 0;
    }
    .dashboard-bg {
        background: linear-gradient(135deg, #fdfbfb 0%, #ebedee 100%);
        padding: 2rem;
        border-radius: 20px;
    }
    .chart-container {
        position: relative;
        height: 300px;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>

<div class="dashboard-bg mt-4">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bolder gradient-text">Dormitory Analytics</h1>
        <p class="text-muted">Real-time overview of occupancy, finances, and maintenance.</p>
    </div>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <style>
            /* 3D Flip Card Styles */
            .flip-card {
                background-color: transparent;
                height: 200px;
                perspective: 1000px; /* Provides 3D effect depth */
            }

            .flip-card-inner {
                position: relative;
                width: 100%;
                height: 100%;
                text-align: center;
                transition: transform 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
                transform-style: preserve-3d;
                box-shadow: 0 8px 30px rgba(0,0,0,0.08);
                border-radius: 16px;
            }

            .flip-card:hover .flip-card-inner {
                transform: rotateY(180deg);
            }

            .flip-card-front, .flip-card-back {
                position: absolute;
                width: 100%;
                height: 100%;
                -webkit-backface-visibility: hidden; /* Safari */
                backface-visibility: hidden;
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
                border-radius: 16px;
                padding: 1.5rem;
            }

            .flip-card-front {
                background: rgba(255, 255, 255, 0.9);
                backdrop-filter: blur(10px);
                border: 1px solid rgba(255, 255, 255, 0.5);
            }

            .flip-card-back {
                background: linear-gradient(135deg, #1cb5e0, #000046);
                color: white;
                transform: rotateY(180deg);
            }
        </style>

        @if (User.IsInRole("Student"))
        {
            <div class="row justify-content-center g-4 mb-5">
                <div class="col-md-5">
                    <div class="card glass-card p-5 border-0 text-center shadow-lg" style="border-radius: 20px;">
                        <i class="bi bi-person-circle display-1 text-primary mb-3"></i>
                        <h3 class="fw-bold gradient-text">Welcome, @ViewBag.StudentName!</h3>
                        <p class="text-muted fs-5">Your Room: <strong class="text-dark">@ViewBag.RoomNumber</strong></p>
                    </div>
                </div>
                <div class="col-md-5">
                    <div class="card glass-card p-5 border-0 text-center shadow-lg" style="border-radius: 20px;">
                        <i class="bi bi-wallet2 display-1 text-danger mb-3"></i>
                        <h3 class="fw-bold text-danger">Outstanding Debt</h3>
                        <p class="text-muted fs-5">Amount: <strong class="text-dark">₺@ViewBag.TotalUnpaid</strong></p>
                        <a asp-controller="Dues" asp-action="Index" class="btn btn-outline-danger rounded-pill mt-2">View Finances</a>
                    </div>
                </div>
            </div>
        }
        else
        {
        <!-- KPI METRICS ROW v3.0 (3D Animated) -->
        <div class="row g-4 mb-5">
            <!-- Card 1: Occupancy -->
            <div class="col-md-3">
                <div class="flip-card">
                    <div class="flip-card-inner">
                        <div class="flip-card-front">
                            <h6 class="text-uppercase text-muted fw-bold mb-3">Occupancy Rate</h6>
                            <h2 class="stat-number text-primary">@ViewBag.TotalStudents</h2>
                            <p class="small text-muted mt-2">Active Students</p>
                        </div>
                        <div class="flip-card-back">
                            <h4>Rooms Overview</h4>
                            <p>Capacity: @ViewBag.TotalCapacity beds</p>
                            <a asp-controller="Rooms" asp-action="Index" class="btn btn-light btn-sm rounded-pill mt-2 fw-bold text-primary">Manage Rooms</a>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Card 2: Revenue -->
            <div class="col-md-3">
                <div class="flip-card">
                    <div class="flip-card-inner">
                        <div class="flip-card-front">
                            <h6 class="text-uppercase text-muted fw-bold mb-3">Collected Revenue</h6>
                            <h2 class="stat-number text-success">₺@ViewBag.TotalPaid</h2>
                            <p class="small text-muted mt-2">Safely in bank</p>
                        </div>
                        <div class="flip-card-back" style="background: linear-gradient(135deg, #11998e, #38ef7d);">
                            <h4>Great Job!</h4>
                            <p>Positive cash flow this month.</p>
                            <a asp-controller="Dues" asp-action="Index" class="btn btn-light btn-sm rounded-pill mt-2 fw-bold text-success">View Details</a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Card 3: Debt -->
            <div class="col-md-3">
                <div class="flip-card">
                    <div class="flip-card-inner">
                        <div class="flip-card-front">
                            <h6 class="text-uppercase text-muted fw-bold mb-3">Outstanding Debt</h6>
                            <h2 class="stat-number text-danger">₺@ViewBag.TotalUnpaid</h2>
                            <p class="small text-muted mt-2">Unpaid dues & penalties</p>
                        </div>
                        <div class="flip-card-back" style="background: linear-gradient(135deg, #ED213A, #93291E);">
                            <h4>Requires Action</h4>
                            <p>Send reminders to students!</p>
                            <a asp-controller="Dues" asp-action="Index" class="btn btn-light btn-sm rounded-pill mt-2 fw-bold text-danger">Chase Debt</a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Card 4: Tickets -->
            <div class="col-md-3">
                <div class="flip-card">
                    <div class="flip-card-inner">
                        <div class="flip-card-front">
                            <h6 class="text-uppercase text-muted fw-bold mb-3">Service Tickets</h6>
                            <h2 class="stat-number text-warning">@ViewBag.PendingTickets</h2>
                            <p class="small text-muted mt-2">Pending maintenance</p>
                        </div>
                        <div class="flip-card-back" style="background: linear-gradient(135deg, #f12711, #f5af19);">
                            <h4>Fix it up!</h4>
                            <p>@ViewBag.ResolvedTickets tickets currently resolved.</p>
                            <a asp-controller="Maintenance" asp-action="Index" class="btn btn-light btn-sm rounded-pill mt-2 fw-bold text-warning">Handle Tickets</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- CHARTS ROW -->
        <div class="row g-4">
            <div class="col-md-6">
                <div class="card glass-card p-4 border-0 h-100">
                    <h4 class="fw-bold mb-4 gradient-text">Financial Health</h4>
                    <div class="chart-container">
                        <canvas id="financeChart"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card glass-card p-4 border-0 h-100">
                    <h4 class="fw-bold mb-4 gradient-text">Maintenance Overview</h4>
                    <div class="chart-container">
                        <canvas id="maintenanceChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- QUICK LINKS -->
        <div class="row mt-5 text-center">
            <div class="col">
                <a asp-controller="Students" asp-action="Index" class="btn btn-outline-primary rounded-pill px-4 me-2">Manage Students</a>
                <a asp-controller="Rooms" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 me-2">Manage Rooms</a>
                <a asp-controller="Dues" asp-action="Index" class="btn btn-outline-success rounded-pill px-4 me-2">Dues & Finances</a>
                <a asp-controller="Maintenance" asp-action="Index" class="btn btn-outline-danger rounded-pill px-4">Service Tickets</a>
            </div>
        </div>
        }
    }
    else
    {
        <div class="row justify-content-center mt-5">
            <div class="col-md-6 text-center">
                <div class="card glass-card p-5 border-0">
                    <h3 class="fw-bold">Welcome to the System</h3>
                    <p class="text-muted mt-3">Please log in to access your administrative dashboard, view financial analytics, and manage student housing operations.</p>
                    <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg mt-4 rounded-pill px-5 shadow">Sign In</a>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        @if (User.Identity?.IsAuthenticated == true && !User.IsInRole("Student"))
        {
            <text>
            // Finance Chart (Pie)
            var ctxFinance = document.getElementById('financeChart').getContext('2d');
            var financeChart = new Chart(ctxFinance, {
                type: 'doughnut',
                data: {
                    labels: ['Collected Revenue (Paid)', 'Outstanding Debt (Unpaid)'],
                    datasets: [{
                        data: [@ViewBag.TotalPaid, @ViewBag.TotalUnpaid],
                        backgroundColor: [
                            'rgba(32, 201, 151, 0.8)', // Success green
                            'rgba(220, 53, 69, 0.8)'   // Danger red
                        ],
                        borderColor: [
                            'rgba(32, 201, 151, 1)',
                            'rgba(220, 53, 69, 1)'
                        ],
                        borderWidth: 2,
                        hoverOffset: 10
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom' },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return context.label + ': ₺' + context.raw;
                                }
                            }
                        }
                    },
                    cutout: '65%'
                }
            });

            // Maintenance Chart (Pie)
            var ctxMaint = document.getElementById('maintenanceChart').getContext('2d');
            var maintenanceChart = new Chart(ctxMaint, {
                type: 'pie',
                data: {
                    labels: ['Pending Tickets', 'Resolved Tickets'],
                    datasets: [{
                        data: [@ViewBag.PendingTickets, @ViewBag.ResolvedTickets],
                        backgroundColor: [
                            'rgba(255, 193, 7, 0.8)', // Warning yellow
                            'rgba(13, 110, 253, 0.8)' // Primary blue
                        ],
                        borderColor: [
                            '#fff',
                            '#fff'
                        ],
                        borderWidth: 3,
                        hoverOffset: 10
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom' }
                    }
                }
            });
            </text>
        }
    </script>
}
