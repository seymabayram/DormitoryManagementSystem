@{
    ViewData["Title"] = "Dashboard";
}

<style>
    /* ── DASHBOARD PAGE STYLES ── */
    .dash-welcome {
        background: linear-gradient(135deg, var(--navy), #25257a);
        border-radius: 20px;
        padding: 32px;
        color: white;
        margin-bottom: 28px;
        position: relative;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(26,31,94,0.15);
    }
    .dash-welcome::after {
        content: '';
        position: absolute;
        top: -60px; right: -60px;
        width: 220px; height: 220px;
        background: radial-gradient(circle, rgba(56, 189, 248, 0.15), transparent 70%);
        border-radius: 50%;
    }
    .dash-welcome::after {
        content: '';
        position: absolute;
        bottom: -40px; right: 80px;
        width: 140px; height: 140px;
        background: rgba(255,209,102,0.08);
        border-radius: 50%;
    }
    .welcome-title {
        font-size: 1.55rem;
        font-weight: 800;
        margin: 0 0 4px;
        letter-spacing: -0.3px;
    }
    .welcome-sub { opacity: 0.78; font-size: 0.9rem; font-weight: 400; }
    .welcome-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(255,209,102,0.2);
        border: 1px solid rgba(255,209,102,0.35);
        color: #FFD166;
        font-size: 0.78rem;
        font-weight: 700;
        padding: 4px 12px;
        border-radius: 20px;
        margin-top: 10px;
    }

    /* ── STAT CARDS ── */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
        gap: 18px;
        margin-bottom: 24px;
    }

    .stat-card {
        background: #ffffff;
        border-radius: 18px;
        padding: 22px 20px;
        border: 1px solid #e2e8f0;
        position: relative;
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        cursor: default;
        perspective: 1000px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }
    .stat-card:hover { transform: translateY(-8px); box-shadow: 0 12px 30px rgba(0,0,0,0.1); border-color: var(--blue); }

    /* Flip inner */
    .stat-flip { transition: transform 0.7s cubic-bezier(0.175,0.885,0.32,1.275); transform-style: preserve-3d; position: relative; min-height: 80px; }
    .stat-card:hover .stat-flip { transform: rotateY(180deg); }

    .stat-front, .stat-back {
        backface-visibility: hidden;
        -webkit-backface-visibility: hidden;
    }
    .stat-back {
        position: absolute;
        inset: 0;
        transform: rotateY(180deg);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: flex-start;
    }

    .stat-icon {
        width: 44px; height: 44px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.15rem;
        margin-bottom: 12px;
        flex-shrink: 0;
    }
    .stat-value {
        font-size: 2.1rem;
        font-weight: 800;
        letter-spacing: -1px;
        line-height: 1;
        margin-bottom: 4px;
    }
    .stat-label { font-size: 0.82rem; font-weight: 600; color: #94a3b8; }
    .stat-trend {
        font-size: 0.75rem;
        font-weight: 700;
        margin-top: 8px;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    /* Color themes */
    .sc-blue  { --sc: #3A6BC7; --sc-lt: #eff6ff; --sc-ico: #dbeafe; }
    .sc-green { --sc: #2D7D4A; --sc-lt: #f0fdf4; --sc-ico: #dcfce7; }
    .sc-gold  { --sc: #d97706; --sc-lt: #fffbeb; --sc-ico: #fef3c7; }
    .sc-red   { --sc: #dc2626; --sc-lt: #fff1f2; --sc-ico: #fee2e2; }

    .stat-icon { background: var(--sc-ico); color: var(--sc); }
    .stat-value { color: var(--sc); }
    .stat-back-desc { font-size: 0.82rem; color: #64748b; font-weight: 500; line-height: 1.5; }

    /* Colored top bar on card */
    .stat-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 4px;
        background: var(--sc);
        border-radius: 4px 4px 0 0;
    }

    /* ── FINANCE SUMMARY CARDS ── */
    .finance-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 18px;
        margin-bottom: 24px;
    }
    .finance-card {
        border-radius: 18px;
        padding: 24px;
        display: flex;
        align-items: center;
        gap: 20px;
        background: #ffffff;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }
    .fin-collected { border-left: 4px solid var(--green) !important; }
    .fin-pending   { border-left: 4px solid #ef4444 !important; }
    .fin-icon {
        width: 52px; height: 52px; border-radius: 14px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem; flex-shrink: 0;
    }
    .fin-collected .fin-icon { background: rgba(74, 222, 128, 0.1); color: var(--green); }
    .fin-pending   .fin-icon { background: rgba(239, 68, 68, 0.1);  color: #ef4444; }
    .fin-amount { font-size: 1.8rem; font-weight: 800; letter-spacing: -0.5px; }
    .fin-collected .fin-amount { color: var(--green); }
    .fin-pending   .fin-amount { color: #f87171; }
    .fin-label { font-size: 0.82rem; color: #64748b; font-weight: 600; margin-top: 2px; }

    /* ── CHARTS ── */
    .charts-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 18px;
        margin-bottom: 24px;
    }
    @@media (max-width: 768px) {
        .charts-grid, .finance-grid { grid-template-columns: 1fr; }
        .stats-grid { grid-template-columns: 1fr 1fr; }
    }
    @@media (max-width: 480px) {
        .stats-grid { grid-template-columns: 1fr; }
    }

    .chart-card {
        background: #ffffff;
        border-radius: 20px;
        padding: 24px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }
    .chart-hdr-icon {
        width: 36px; height: 36px; border-radius: 10px;
        background: rgba(56, 189, 248, 0.1); color: var(--blue);
        display: flex; align-items: center; justify-content: center;
        font-size: 1rem;
    }
    .chart-hdr-title { font-weight: 700; font-size: 1rem; color: var(--navy); }
    .chart-hdr-sub   { font-size: 0.8rem; color: #64748b; font-weight: 500; }
    .chart-body { position: relative; height: 220px; }

    /* ── STUDENT SPECIFIC ── */
    .student-profile-card {
        background: #ffffff;
        border-radius: 20px;
        padding: 28px;
        border: 1px solid #e2e8f0;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 24px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }
    .student-avatar {
        width: 72px; height: 72px; border-radius: 18px;
        background: linear-gradient(135deg, var(--blue), var(--blue-lt));
        display: flex; align-items: center; justify-content: center;
        font-size: 1.8rem; font-weight: 800; color: white; flex-shrink: 0;
    }
    .student-name  { font-size: 1.4rem; font-weight: 800; color: var(--navy); }
    .student-meta  { font-size: 0.9rem; color: #94a3b8; margin-top: 4px; }
</style>

<!-- Welcome Banner -->
<div class="dash-welcome" data-aos="fade-down">
    <div style="position:relative; z-index:2;">
        <div class="welcome-title">
            @if (User.IsInRole("Admin"))
            {
                <span>Welcome back, Admin 👋</span>
            }
            else if (User.IsInRole("Staff"))
            {
                <span>Hello, @User.Identity?.Name 👋</span>
            }
            else
            {
                <span>Hi, @ViewBag.StudentName 👋</span>
            }
        </div>
        <div class="welcome-sub">Here's what's happening in the dormitory today.</div>
        @if (User.IsInRole("Admin"))
        {
            <div class="welcome-badge"><i class="bi bi-shield-fill-check"></i> Administrator</div>
        }
        else if (User.IsInRole("Staff"))
        {
            <div class="welcome-badge" style="color:#5DD68A; border-color:rgba(93,214,138,0.35); background:rgba(93,214,138,0.1);"><i class="bi bi-person-badge-fill"></i> Staff Member</div>
        }
        else
        {
            <div class="welcome-badge" style="color:#8AB4F8; border-color:rgba(138,180,248,0.35); background:rgba(138,180,248,0.1);"><i class="bi bi-mortarboard-fill"></i> Resident Student</div>
        }
    </div>
</div>

@if (User.IsInRole("Student"))
{
    <!-- Student Profile Card -->
    <div class="student-profile-card" data-aos="fade-up">
        <div class="student-avatar">
            @(ViewBag.StudentName?.ToString()?.Substring(0, 1) ?? "S")
        </div>
        <div>
            <div class="student-name">@ViewBag.StudentName</div>
            <div class="student-meta"><i class="bi bi-door-open me-1"></i>Room <strong>@ViewBag.RoomNumber</strong> &nbsp;·&nbsp; <i class="bi bi-person-check me-1"></i>Active Resident</div>
        </div>
    </div>

    <!-- Student Finance Cards -->
    <div class="finance-grid" data-aos="fade-up" data-aos-delay="100">
        <div class="finance-card fin-collected">
            <div class="fin-icon"><i class="bi bi-check-circle-fill"></i></div>
            <div>
                <div class="fin-amount">@(((decimal)(ViewBag.TotalPaid ?? 0m)).ToString("N0")) ₺</div>
                <div class="fin-label">Total Paid</div>
            </div>
        </div>
        <div class="finance-card fin-pending">
            <div class="fin-icon"><i class="bi bi-exclamation-circle-fill"></i></div>
            <div>
                <div class="fin-amount">@(((decimal)(ViewBag.TotalUnpaid ?? 0m)).ToString("N0")) ₺</div>
                <div class="fin-label">Outstanding Balance</div>
            </div>
        </div>
    </div>
}
else
{
    <!-- Admin / Staff Stat Cards -->
    <div class="stats-grid" data-aos="fade-up">
        <!-- Units -->
        <div class="stat-card sc-blue">
            <div class="stat-flip">
                <div class="stat-front">
                    <div class="stat-icon"><i class="bi bi-building"></i></div>
                    <div class="stat-value">@ViewBag.TotalCapacity</div>
                    <div class="stat-label">Total Bed Capacity</div>
                    <div class="stat-trend" style="color:#3A6BC7;"><i class="bi bi-arrow-up-right"></i> Registered Units</div>
                </div>
                <div class="stat-back">
                    <div class="stat-icon"><i class="bi bi-building"></i></div>
                    <div class="stat-back-desc mt-2">Total physical bed capacity and unit volume defined in the system.</div>
                </div>
            </div>
        </div>

        <!-- Residents -->
        <div class="stat-card sc-green">
            <div class="stat-flip">
                <div class="stat-front">
                    <div class="stat-icon"><i class="bi bi-people-fill"></i></div>
                    <div class="stat-value">@ViewBag.TotalStudents</div>
                    <div class="stat-label">Current Residents</div>
                    <div class="stat-trend" style="color:#2D7D4A;"><i class="bi bi-person-check"></i> Active Students</div>
                </div>
                <div class="stat-back">
                    <div class="stat-icon"><i class="bi bi-people-fill"></i></div>
                    <div class="stat-back-desc mt-2">Students currently and actively residing in the facility.</div>
                </div>
            </div>
        </div>

        <!-- Occupancy -->
        <div class="stat-card sc-gold">
            <div class="stat-flip">
                <div class="stat-front">
                    <div class="stat-icon"><i class="bi bi-bar-chart-fill"></i></div>
                    <div class="stat-value">@ViewBag.TotalStudents<span style="font-size:1rem;opacity:0.5;">/@ViewBag.TotalCapacity</span></div>
                    <div class="stat-label">Beds Occupied</div>
                    <div class="stat-trend" style="color:#d97706;"><i class="bi bi-percent"></i> Occupancy Rate</div>
                </div>
                <div class="stat-back">
                    <div class="stat-icon"><i class="bi bi-bar-chart-fill"></i></div>
                    <div class="stat-back-desc mt-2">Active bed occupancy vs. total available capacity.</div>
                </div>
            </div>
        </div>

        <!-- Maintenance -->
        <div class="stat-card sc-red">
            <div class="stat-flip">
                <div class="stat-front">
                    <div class="stat-icon"><i class="bi bi-tools"></i></div>
                    <div class="stat-value">@ViewBag.PendingTickets</div>
                    <div class="stat-label">Pending Requests</div>
                    <div class="stat-trend" style="color:#dc2626;"><i class="bi bi-clock-fill"></i> Open Maintenance</div>
                </div>
                <div class="stat-back">
                    <div class="stat-icon"><i class="bi bi-tools"></i></div>
                    <div class="stat-back-desc mt-2">Unresolved maintenance and repair requests from residents.</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Finance Summary -->
    <div class="finance-grid" data-aos="fade-up" data-aos-delay="50">
        <div class="finance-card fin-collected">
            <div class="fin-icon"><i class="bi bi-wallet2"></i></div>
            <div>
                <div class="fin-amount">@(((decimal)(ViewBag.TotalPaid ?? 0m)).ToString("N0")) ₺</div>
                <div class="fin-label">Revenue Collected</div>
            </div>
        </div>
        <div class="finance-card fin-pending">
            <div class="fin-icon"><i class="bi bi-exclamation-diamond-fill"></i></div>
            <div>
                <div class="fin-amount">@(((decimal)(ViewBag.TotalUnpaid ?? 0m)).ToString("N0")) ₺</div>
                <div class="fin-label">Revenue Outstanding</div>
            </div>
        </div>
    </div>

    <!-- Charts -->
    <div class="charts-grid" data-aos="fade-up" data-aos-delay="100">
        <div class="chart-card">
            <div class="chart-hdr">
                <div class="chart-hdr-icon"><i class="bi bi-pie-chart-fill"></i></div>
                <div>
                    <div class="chart-hdr-title">Financial Overview</div>
                    <div class="chart-hdr-sub">Collected vs. Outstanding</div>
                </div>
            </div>
            <div class="chart-body"><canvas id="financeChart"></canvas></div>
        </div>
        <div class="chart-card">
            <div class="chart-hdr">
                <div class="chart-hdr-icon"><i class="bi bi-wrench-adjustable"></i></div>
                <div>
                    <div class="chart-hdr-title">Maintenance Pulse</div>
                    <div class="chart-hdr-sub">Pending vs. Resolved</div>
                </div>
            </div>
            <div class="chart-body"><canvas id="maintenanceChart"></canvas></div>
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        @if (!User.IsInRole("Student"))
        {
            <text>
            // Doughnut — Finance
            new Chart(document.getElementById('financeChart').getContext('2d'), {
                type: 'doughnut',
                data: {
                    labels: ['Collected', 'Outstanding'],
                    datasets: [{
                        data: [@ViewBag.TotalPaid, @ViewBag.TotalUnpaid],
                        backgroundColor: ['#2D7D4A', '#dc2626'],
                        borderWidth: 0,
                        hoverOffset: 8
                    }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'right',
                            labels: { color: '#64748b', usePointStyle: true, boxWidth: 12, padding: 20, font: { family: 'Outfit', size: 12, weight: '600' } }
                        }
                    },
                    cutout: '76%'
                }
            });

            // Bar — Maintenance
            new Chart(document.getElementById('maintenanceChart').getContext('2d'), {
                type: 'bar',
                data: {
                    labels: ['Pending', 'Resolved'],
                    datasets: [{
                        data: [@ViewBag.PendingTickets, @ViewBag.ResolvedTickets],
                        backgroundColor: ['rgba(220,38,38,0.18)', 'rgba(45,125,74,0.18)'],
                        borderColor:     ['#dc2626', '#2D7D4A'],
                        borderWidth: 2,
                        borderRadius: 8,
                        barThickness: 48
                    }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    scales: {
                        y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.04)' }, ticks: { color:'#94a3b8', stepSize:1, font:{family:'Outfit'} }, border:{display:false} },
                        x: { grid: { display:false }, ticks: { color:'#94a3b8', font:{family:'Outfit',weight:'600'} } }
                    },
                    plugins: { legend: { display:false } }
                }
            });
            </text>
        }
    </script>
}
